# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=https://bountytask.dpdns.org

# Paystack — bank list + bank account number verification, withdrawal
# verification-fee payments, and advertiser payments (single provider for all three).
# Checkout is redirect-based (Transaction Initialize API), so only the secret
# key is needed — nothing Paystack-related runs in the browser anymore.
PAYSTACK_SECRET_KEY=sk_test_your_paystack_key

# Cloudinary — stores all uploaded files (profile avatars, task-completion
# proof screenshots/PDFs/videos). Uploads always go through our own API
# routes (src/app/api/upload/*), never directly from the browser, so only
# the server needs these — no NEXT_PUBLIC_ variant required.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# TextBee (SMS gateway — sends via a linked Android device, no per-message billing)
# Only needed if phone verification is enabled in Admin Settings.
TEXTBEE_API_KEY=your-textbee-api-key
TEXTBEE_DEVICE_ID=your-textbee-device-id

# Email (pick one)
RESEND_API_KEY=re_your_resend_key
# BREVO_API_KEY=your-brevo-key

# Admin config
ADMIN_EMAIL=admin@bountytask.dpdns.org

# Cron secret (used by GitHub Actions to authenticate cron routes)
CRON_SECRET=your-super-secret-cron-key
