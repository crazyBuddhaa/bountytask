# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Flutterwave (v4 API) — bank list + bank account number verification
# Uses OAuth2 client-credentials auth. Get these from Settings > API Keys
# on your Flutterwave dashboard (v4 issues Client ID + Client Secret,
# not a static secret key). The Encryption Key shown alongside them is
# only used for direct card charges and is not needed here.
# https://developer.flutterwave.com/docs/authentication
FLUTTERWAVE_CLIENT_ID=your-flutterwave-client-id
FLUTTERWAVE_CLIENT_SECRET=your-flutterwave-client-secret
# "production" (default) or "sandbox"
FLUTTERWAVE_ENV=production

# Paystack (kept for withdrawal verification-fee + advertiser payments — no longer used for
# bank account verification, see Flutterwave keys above; safe to leave unset until those flows go live)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_key
# Only needed if the withdrawal verification fee's payment method is set to "paystack"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_key

# TextBee (SMS gateway — sends via a linked Android device, no per-message billing)
# Only needed if phone verification is enabled in Admin Settings.
TEXTBEE_API_KEY=your-textbee-api-key
TEXTBEE_DEVICE_ID=your-textbee-device-id

# Email (pick one)
RESEND_API_KEY=re_your_resend_key
# BREVO_API_KEY=your-brevo-key

# Admin config
ADMIN_EMAIL=admin@yourdomain.com

# Cron secret (used by GitHub Actions to authenticate cron routes)
CRON_SECRET=your-super-secret-cron-key
